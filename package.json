{
  "name": "@iteachyouai/deploy-gate",
  "version": "0.1.0",
  "description": "Pre-deploy checklist MCP server — catches what CI misses",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "deploy-gate": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/checks/secret-patterns.json dist/checks/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "deploy",
    "checklist",
    "pre-deploy",
    "ci",
    "claude",
    "ai-coding"
  ],
  "author": "ITeachYouAI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ITeachYouAI/deploy-gate.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
